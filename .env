# HTTP server configuration
# Precedence: CLI args > real environment > this file > built-in defaults

PORT=8080
# Static file root. Points at the bundled demo site (index.html + CSS + JS).
DOCUMENT_ROOT=www

# CORS: origin echoed in Access-Control-Allow-Origin ("*" allows any origin).
CORS_ALLOW_ORIGIN=*

# Rate limiting: token bucket per client IP. RPS is the sustained refill rate;
# BURST is the bucket size (the largest instantaneous burst allowed). Set
# RATE_LIMIT_ENABLED=false to turn it off.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# API key auth: comma-separated list of accepted keys. When empty, auth is
# disabled and every route is open. When set, mutating requests (POST/PUT/
# DELETE/PATCH) must present a key via "X-API-Key: <key>" or
# "Authorization: Bearer <key>"; reads stay public. Leave empty for the demo.
API_KEYS=

# TLS
SSL_ENABLED=true
SSL_CERT_FILE=server.crt
SSL_KEY_FILE=server.key

# Load balancer (codo-balancer)
# BALANCER_PORT      listen port for the balancer
# BALANCER_BACKENDS  comma-separated backend list: host:port[:weight]
BALANCER_PORT=8000
BALANCER_BACKENDS=127.0.0.1:8080