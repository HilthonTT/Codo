# HTTP server configuration
# Precedence: CLI args > real environment > this file > built-in defaults

PORT=8080
# Static file root. Points at the bundled demo site (index.html + CSS + JS).
DOCUMENT_ROOT=www

# CORS: origin echoed in Access-Control-Allow-Origin ("*" allows any origin).
CORS_ALLOW_ORIGIN=*

# TLS
SSL_ENABLED=true
SSL_CERT_FILE=server.crt
SSL_KEY_FILE=server.key

# Load balancer (codo-balancer)
# BALANCER_PORT      listen port for the balancer
# BALANCER_BACKENDS  comma-separated backend list: host:port[:weight]
BALANCER_PORT=8000
BALANCER_BACKENDS=127.0.0.1:8080